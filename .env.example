# ═══════════════════════════════════════
# CORE IDENTITY
# ═══════════════════════════════════════
CLIENT_NAME="Acme Corp"
AGENT_NAME="Alex"
COMPANY_DESCRIPTION="We sell premium home appliances online."
AGENT_TONE="professional and friendly"
AGENT_MODE="both"   # customer_service | sales | both

# Custom business rules (one per line, separated by newlines)
# These are injected into the AI agent's system prompt
CUSTOM_BUSINESS_RULES="Never offer discounts above 10%.\nAlways recommend accessories with main products.\nDo not discuss competitor products."

# ═══════════════════════════════════════
# LLM CONFIGURATION (OpenRouter)
# ═══════════════════════════════════════
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="openai/gpt-4o"
LLM_FAST_MODEL="openai/gpt-4o-mini"
LLM_TEMPERATURE="0.3"
LLM_MAX_TOKENS="1024"
EMBEDDING_MODEL="openai/text-embedding-3-small"

# ═══════════════════════════════════════
# SHOPIFY
# ═══════════════════════════════════════
SHOPIFY_STORE_DOMAIN="acmecorp.myshopify.com"
SHOPIFY_ADMIN_API_TOKEN="shpat_..."
SHOPIFY_API_VERSION="2025-01"
SHOPIFY_WEBHOOK_SECRET="wh_secret_xyz..."
SHOPIFY_LOCATION_ID="12345678"
SHOPIFY_CURRENCY="INR"
SHOPIFY_RETURN_POLICY_URL="https://acmecorp.com/returns"
SHOPIFY_TRACKING_URL_TEMPLATE="https://track.delhivery.com/{tracking_number}"
SHOPIFY_RETURN_WINDOW_DAYS="7"

# ═══════════════════════════════════════
# TWILIO WHATSAPP (set WHATSAPP_ENABLED=false to disable)
# ═══════════════════════════════════════
WHATSAPP_ENABLED="true"
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ═══════════════════════════════════════
# EMAIL (set EMAIL_ENABLED=false to disable)
# ═══════════════════════════════════════
EMAIL_ENABLED="true"
EMAIL_INBOUND_ADDRESS="support@acmecorp.com"
SENDGRID_API_KEY="SG...."
SENDGRID_INBOUND_WEBHOOK_SECRET=""
EMAIL_FROM_ADDRESS="support@acmecorp.com"
EMAIL_FROM_NAME="Alex from Acme Support"
EMAIL_BRAND_LOGO_URL="https://acmecorp.com/logo.png"
EMAIL_BRAND_PRIMARY_COLOR="#2563EB"
EMAIL_BRAND_COMPANY_NAME="Acme Corp"

# ═══════════════════════════════════════
# INSTAGRAM (set INSTAGRAM_ENABLED=false to disable)
# ═══════════════════════════════════════
INSTAGRAM_ENABLED="true"
INSTAGRAM_ACCESS_TOKEN="EAA..."
INSTAGRAM_PAGE_ID="123456789"
INSTAGRAM_APP_SECRET="abc..."
INSTAGRAM_WEBHOOK_VERIFY_TOKEN="insta_token_xyz"

# ═══════════════════════════════════════
# ESCALATION
# ═══════════════════════════════════════
ESCALATION_EMAIL_TO="team@acmecorp.com"
ESCALATION_EMAIL_FROM="alerts@acmecorp.com"
ESCALATION_LEAD_SCORE_THRESHOLD="70"
ESCALATION_CONFIDENCE_THRESHOLD="0.4"

# ═══════════════════════════════════════
# ADMIN DASHBOARD
# ═══════════════════════════════════════
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"

# ═══════════════════════════════════════
# SIMULATOR
# ═══════════════════════════════════════
SIMULATOR_ENABLED="true"

# ═══════════════════════════════════════
# SLA
# ═══════════════════════════════════════
SLA_FIRST_RESPONSE_SECONDS="5"
SLA_RESOLUTION_HOURS="24"
SLA_MAX_RETRIES="3"
SLA_FOLLOWUP_HOURS="24"

# ═══════════════════════════════════════
# SESSION
# ═══════════════════════════════════════
SESSION_TTL_HOURS="24"

# ═══════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════
DATABASE_URL="postgresql+asyncpg://agent:agent_dev@localhost:5432/omnichannel_agent"
REDIS_URL="redis://localhost:6379/0"
